{
  "framework": "django",
  "installCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "datingapp/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "datingapp/wsgi.py"
    }
  ]
}
